{
  "permissions": {
    "deny": [
      "Write(./.pre-commit-config.yaml)",
      "Edit(./.pre-commit-config.yaml)",
      "Write(./pyproject.toml)",
      "Edit(./pyproject.toml)",
      "Read(./.env)",
      "Bash(cat .env)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "network": {
      "allowedDomains": [
        "api.anthropic.com",
        "github.com",
        "*.github.com",
        "*.githubusercontent.com",
        "pypi.org",
        "files.pythonhosted.org",
        "registry.npmjs.org"
      ]
    }
  }
}