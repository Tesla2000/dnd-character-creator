{
  "$schema": "https://www.schemastore.org/claude-code-keybindings.json",
  "$docs": "https://code.claude.com/docs/en/keybindings",
  "bindings": [
    {
      "context": "Autocomplete",
      "bindings": {
        "escape": null,
        "ctrl+q": "autocomplete:dismiss"
      }
    },
    {
      "context": "Help",
      "bindings": {
        "escape": null,
        "ctrl+q": "help:dismiss"
      }
    },
    {
      "context": "DiffDialog",
      "bindings": {
        "escape": null,
        "ctrl+q": "diff:dismiss"
      }
    },
    {
      "context": "Select",
      "bindings": {
        "escape": null,
        "ctrl+q": "select:cancel"
      }
    }
  ]
}
